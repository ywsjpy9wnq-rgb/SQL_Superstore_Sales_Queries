library(readr)
library(dplyr)
library(ggplot2)
library(RSQLite)
sales <- read_csv("/Users/matthewgibbs/Documents/Work/Current/Portfolio/Coding/Superstore sales datASet.csv")
head(sales)
str(sales)
names(sales)
sales$Year_Month <- format(sales$`Order Date`, "%Y-%m")
#Data cleaning for date (convert to correct format)
library(lubridate)
# Convert order date to correct format
sales$`Order Date` <- as.Date(sales$`Order Date`, format = "%d/%m/%Y")
sales$Year_Month <- format(sales$`Order Date`, "%Y-%m")
sales$`Ship Date` <- as.Date(sales$`Ship Date`, format = "%d/%m/%Y")
sales <- sales %>% arrange(`Order Date`)
#Convert to Characters for SQL (otherwise converts to excel format)
sales$`Order Date` <- as.character(sales$`Order Date`)
sales$`Ship Date` <- as.character(sales$`Ship Date`)
head(sales, 15)
conn <- dbConnect(SQLite(), "superstore.db")
dbWriteTable(conn, "orders", sales, overwrite = TRUE)
dbListTables(conn)
dbGetQuery(conn, "
SELECT
Region,
ROUND(SUM(Sales), 2) AS `Total Sales`,
ROUND(AVG(Sales), 2) AS `Avg Sale`,
COUNT(*) AS Num_Orders
FROM orders
GROUP BY Region
ORDER BY `Total Sales` DESC
")
dbGetQuery(conn, "
SELECT
Region,
ROUND(SUM(Sales), 2) AS `Total Sales`,
ROUND(AVG(Sales), 2) AS `Avg Sale`,
COUNT(*) AS Num_Orders
FROM orders
GROUP BY Region
ORDER BY `Total Sales` DESC
")
